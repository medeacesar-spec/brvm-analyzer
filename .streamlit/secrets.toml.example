# =============================================================================
# BRVM Analyzer — Configuration secrets
# =============================================================================
# Renommez ce fichier en `secrets.toml` et remplissez les valeurs.
# NE JAMAIS committer ce fichier dans git (il est dans .gitignore).
#
# Pour Streamlit Cloud : copier/coller le contenu dans Settings → Secrets.
# =============================================================================


# -----------------------------------------------------------------------------
# Base de données (optionnel — par défaut SQLite locale)
# -----------------------------------------------------------------------------
# Pour Supabase / Neon Postgres :
# DATABASE_URL = "postgresql://user:password@host:5432/dbname?sslmode=require"


# -----------------------------------------------------------------------------
# Authentification Google OAuth (Streamlit v1.42+)
# -----------------------------------------------------------------------------
# Prérequis : créer un OAuth Client dans Google Cloud Console
#   1. https://console.cloud.google.com/apis/credentials
#   2. Créer → ID client OAuth → Application Web
#   3. Redirect URIs:
#      - Local : http://localhost:8501/oauth2callback
#      - Prod  : https://<your-app>.streamlit.app/oauth2callback
#   4. Copier Client ID + Client Secret ci-dessous
#
# Documentation : https://docs.streamlit.io/develop/api-reference/user/st.login

[auth]
# Chaîne aléatoire longue, utilisée pour signer les cookies de session.
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
cookie_secret = "REMPLACEZ-MOI-AVEC-UNE-CHAINE-ALEATOIRE-DE-64-CARS"

# URL de callback OAuth. Doit correspondre à l'URI Google Cloud.
redirect_uri = "http://localhost:8501/oauth2callback"

# Restreindre aux utilisateurs autorisés (liste d'emails)
# Optionnel — commenter pour autoriser tout compte Google
# allowed_emails = ["alice@example.com", "bob@example.com"]


[auth.google]
client_id = "VOTRE_CLIENT_ID.apps.googleusercontent.com"
client_secret = "VOTRE_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
